{
  "name": "merchant-ui",
  "version": "1.0.0",
  "private": true,
  "description": "商户端",
  "templateInfo": {
    "name": "default",
    "typescript": false,
    "css": "Sass",
    "framework": "Vue3"
  },
  "scripts": {
    "prepare": "echo 'husky disabled'",
    "new": "taro new",
    "build:weapp": "taro build --type weapp",
    "build:swan": "taro build --type swan",
    "build:alipay": "taro build --type alipay",
    "build:tt": "taro build --type tt",
    "build:h5": "taro build --type h5",
    "build:rn": "taro build --type rn",
    "build:qq": "taro build --type qq",
    "build:jd": "taro build --type jd",
    "build:harmony-hybrid": "taro build --type harmony-hybrid",
    "dev:weapp": "taro build --type weapp --watch --env development",
    "dev:swan": "npm run build:swan -- --watch",
    "dev:alipay": "npm run build:alipay -- --watch",
    "dev:tt": "npm run build:tt -- --watch",
    "dev:h5": "npm run build:h5 -- --watch",
    "dev:rn": "npm run build:rn -- --watch",
    "dev:qq": "npm run build:qq -- --watch",
    "dev:jd": "npm run build:jd -- --watch",
    "dev:harmony-hybrid": "npm run build:harmony-hybrid -- --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "browserslist": [
    "defaults and fully supports es6-module",
    "maintained node versions"
  ],
  "author": "",
  "dependencies": {
    "@babel/runtime": "^7.24.4",
    "@nutui/nutui-taro": "^4.3.14",
    "@tarojs/components": "4.1.11",
    "@tarojs/helper": "4.1.11",
    "@tarojs/plugin-framework-vue3": "4.1.11",
    "@tarojs/plugin-platform-alipay": "4.1.11",
    "@tarojs/plugin-platform-h5": "4.1.11",
    "@tarojs/plugin-platform-harmony-hybrid": "4.1.11",
    "@tarojs/plugin-platform-jd": "4.1.11",
    "@tarojs/plugin-platform-qq": "4.1.11",
    "@tarojs/plugin-platform-swan": "4.1.11",
    "@tarojs/plugin-platform-tt": "4.1.11",
    "@tarojs/plugin-platform-weapp": "4.1.11",
    "@tarojs/runtime": "4.1.11",
    "@tarojs/shared": "4.1.11",
    "@tarojs/taro": "4.1.11",
    "pinia": "^3.0.4",
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@babel/core": "^7.24.4",
    "@babel/plugin-transform-class-properties": "7.25.9",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@tarojs/cli": "4.1.11",
    "@tarojs/plugin-generator": "4.1.11",
    "@tarojs/vite-runner": "4.1.11",
    "@types/minimatch": "^5",
    "@upstash/context7-mcp": "^2.1.4",
    "@vitejs/plugin-vue": "^4.6.2",
    "@vitejs/plugin-vue-jsx": "^3.1.0",
    "babel-preset-taro": "4.1.11",
    "eslint": "^8.57.0",
    "eslint-config-taro": "4.1.11",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "postcss": "^8.5.6",
    "react-refresh": "^0.14.0",
    "sass": "^1.75.0",
    "sharp": "^0.34.5",
    "stylelint": "^16.4.0",
    "stylelint-config-standard": "^38.0.0",
    "terser": "^5.30.4",
    "vite": "^4.2.0",
    "vitest": "^1.6.1"
  }
}
